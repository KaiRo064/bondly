# Bondly .gitignore

# Environment variables
.env
.env.local
.env.*.local

# IDE & Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# PHP
composer.lock
vendor/
*.log

# Database
*.sql.bak
backup/
database-backup/

# Uploads (for local development)
public/uploads/profiles/*
!public/uploads/profiles/.gitkeep
public/uploads/posts/*
!public/uploads/posts/.gitkeep

# OS files
.DS_Store
.AppleDouble
.LSOverride
._*

# Cache
.cache/
cache/

# Temp files
tmp/
temp/

# Node (if using)
node_modules/
package-lock.json
yarn.lock
